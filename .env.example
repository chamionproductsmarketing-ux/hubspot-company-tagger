# HubSpot private app access token
HUBSPOT_ACCESS_TOKEN=

# Webhook signature secret (HubSpot App → Webhooks → Client secret)
# Leave empty to skip signature verification during development
HUBSPOT_WEBHOOK_SECRET=

# Optional: only trigger tagging when deals enter this specific stage
# Leave empty to tag on ANY deal stage change
# Example: closedwon
DEAL_STAGE_TRIGGER=

# Optional: protect the backfill endpoint with a secret key
# Usage: GET /api/hubspot/backfill?key=YOUR_KEY
BACKFILL_KEY=
